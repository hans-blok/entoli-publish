    <folder name="goal" id="id-f52e5ae446b7437eb5aec5924e2f19f9">
      <element xsi:type="archimate:Goal" name="Accessibility for users" id="id-82435fa9f4d342599977d25fe6e98427">
        <documentation>The system is usable by teams/clients without the original creators</documentation>
      </element>
      <element xsi:type="archimate:Driver" name="Complexity of knowledge and architecture is increasing" id="id-7b0d416f793e4b619b1b12311eda8110"/>
      <element xsi:type="archimate:Driver" name="Dependency on individuals makes systems vulnerable" id="id-cd8cbadd16e144aa90a724595a41691d"/>
      <element xsi:type="archimate:Driver" name="Need for reproducible and transferable systems" id="id-4fa6e44d301c49deb175ee7d6e2b7f3e"/>
      <element xsi:type="archimate:Goal" name="Operationally deployable ecosystem" id="id-6b3c0015f8444b3f91a633ea260da9ad">
        <documentation>A working system exists that actually produces artifacts</documentation>
      </element>
      <element xsi:type="archimate:Goal" name="Reusable knowledge base" id="id-2ddcd87316c54f1fb9e0b8a040668a28">
        <documentation>Knowledge is explicitly recorded and deployable independent of individual people</documentation>
      </element>
    </folder>
    <folder name="contraint" id="id-4b196e18c0944fa3a337fbe757fae76c">
