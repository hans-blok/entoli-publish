  <folder name="Motivation" id="id-aeb7b54d4a7f4f979dc20cd0246b4e9c" type="motivation">
    <folder name="req" id="id-0b3e3e1e890e4d6fb0d5688b7385f000">
      <folder name="source regime" id="id-041c22bf4f464036a853f3352f063653">
        <element xsi:type="archimate:Constraint" name="Canon-bound" id="id-31c5d3ed2e9c4cefbc28d7b187301c16">
          <documentation>- **Canon-bound**  &#xD;
  Only explicitly recorded canonical artefacts may be used as a source.  &#xD;
  Interpretation within the canon is permitted; external sources are not.&#xD;
&#xD;
</documentation>
        </element>
        <element xsi:type="archimate:Constraint" name="External-source-bound" id="id-a76a558cb861412b98059d6a31db5a8f">
          <documentation>- **External-source-bound**  &#xD;
  Specifically named external sources (e.g. legislation, standards, market information) may be consulted.  &#xD;
  The sources used must be explicitly traceable.&#xD;
&#xD;
</documentation>
        </element>
        <element xsi:type="archimate:Constraint" name="Input-bound" id="id-69edef7ff33a4efcb6a5f5bef66d1762">
          <documentation> **Input-bound**  &#xD;
  Only the explicitly supplied input forms the permitted source space.  &#xD;
  No external sources, no canonical artefacts, no additional knowledge.  &#xD;
  Equal input yields equal output (deterministic in nature).&#xD;
&#xD;
</documentation>
        </element>
        <element xsi:type="archimate:Constraint" name="Open" id="id-7c1a94cf3c1e455fadfb98818b1c5c02">
          <documentation>- **Exploratory**  &#xD;
  The source space is open. New sources may be explored and identified.  &#xD;
  Results have no normative status until selection has taken place.</documentation>
        </element>
      </folder>
